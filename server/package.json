{
  "name": "node-server",
  "version": "1.0.0",
  "main": "index.ts",
  "prisma": {
    "schema": "./prisma/schema.prisma"
  },
  "scripts": {
    "services": "wsl --exec dbus-launch true",
    "cli": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/cli.ts",
    "sandbox:stripe": "stripe listen --forward-to localhost:3001/user/webhook/stripe",
    "prebuild:version": "node version.js",
    "prebuild": "npm run prebuild:version",
    "dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/index.ts",
    "build": "npm run prebuild && esbuild src/index.ts --bundle --platform=node --outfile=dist/index.js",
    "start": "node dist/index.js",
    "live": "npm run build && npm run start",
    "deploy": "./deploy.sh"
  },
  "author": "Darshan Nagle",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@mrleebo/prisma-ast": "^0.15.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^6.19.3",
    "axios": "^1.7.7",
    "chalk": "^4.1.2",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-ejs-layouts": "^2.5.1",
    "express-flash-message": "^3.0.2",
    "express-session": "^1.18.1",
    "express-useragent": "^1.0.15",
    "inquirer": "^12.6.3",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.30.1",
    "moment-timezone": "^0.5.46",
    "multer": "^2.0.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^7.0.3",
    "pg": "^8.16.0",
    "puppeteer": "^24.15.0",
    "qr-image-color": "^3.2.1",
    "redis": "^4.7.1",
    "reflect-metadata": "^0.2.2",
    "speakeasy": "^2.0.0",
    "stripe": "^18.5.0",
    "typeorm": "^0.3.24",
    "ua-parser-js": "^2.0.9",
    "ulid": "^3.0.1",
    "upstox-js-sdk": "^2.11.0",
    "uuid": "^11.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/ejs": "^3.1.5",
    "@types/express": "^4.17.17",
    "@types/express-ejs-layouts": "^2.5.4",
    "@types/express-session": "^1.18.1",
    "@types/express-useragent": "^1.0.5",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^1.4.13",
    "@types/node": "^25.9.4",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.17",
    "@types/speakeasy": "^2.0.10",
    "@types/ws": "^8.5.13",
    "esbuild": "^0.25.5",
    "fs": "^0.0.1-security",
    "prisma": "^6.19.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
